# OpenFactory — Environment Variables
# Copy to .env and fill in values. Never commit .env.

# API server
PORT=3000

# SQLite database path (defaults to data/openfactory.db)
DB_PATH=data/openfactory.db

# JWT secret — change this in production!
JWT_SECRET=change-this-to-a-random-64-char-string-in-production

# Slack notifications (optional — for health check alerts)
# Get from https://api.slack.com/apps → OAuth & Permissions → Bot Token
SLACK_BOT_TOKEN=xoxb-your-token-here
SLACK_CHANNEL=C0AHA1P0XS4

# WeChat webhook (optional — Phase 1)
# WECHAT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=YOUR_KEY

# Stripe escrow (optional — Phase 2)
# STRIPE_SECRET_KEY=sk_live_your-key-here
# STRIPE_WEBHOOK_SECRET=whsec_your-secret-here
